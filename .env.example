# Smart Caffeine Analytics Environment Variables

# Airtable
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_base_id_here

# Meta/Facebook Ads
META_APP_ID=your_actual_app_id
META_APP_SECRET=your_actual_secret
META_ACCESS_TOKEN=your_actual_token
META_AD_ACCOUNT_ID=act_your_account_id

# Shopify
SHOPIFY_SHOP_NAME=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_actual_token

# Google Ads (TODO)
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Legacy variable names (for backward compatibility)
FACEBOOK_ADS_API_KEY=your_facebook_ads_api_key_here
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_STORE_URL=your-store.myshopify.com